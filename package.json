{
  "name": "github-mcp-server",
  "version": "1.0.0",
  "description": "A fully automated GitHub MCP Server for Claude Desktop",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "start:remote": "tsx src/server-remote.ts",
    "build": "tsc",
    "build:check": "tsc --noEmit",
    "dev": "tsx --watch src/index.ts"
  },
  "keywords": [
